        MENUITEM "H&elyettesítő kijelölés visszavonás...\tCtrl+Shift+S", IDM_EDIT_WILDCARDDESELECT
    END
    POPUP "Né&zet"
    BEGIN
        MENUITEM "&Állapotsor",                 IDM_VIEW_STATUSBAR
        MENUITEM "&Mappák",                     IDM_VIEW_FOLDERS
        MENUITEM "&Részletek ablak",            IDM_VIEW_DISPLAYWINDOW
        POPUP "&Eszköztárak"
        BEGIN
            MENUITEM "&Címsor",                     IDM_TOOLBARS_ADDRESSBAR
            MENUITEM "&Főeszköztár",                IDM_TOOLBARS_MAINTOOLBAR
            MENUITEM "&Könyvjelzők",                IDM_TOOLBARS_BOOKMARKSTOOLBAR
            MENUITEM "&Lemezek",                    IDM_TOOLBARS_DRIVES
            MENUITEM "&Alkalmazások eszköztár",     IDM_TOOLBARS_APPLICATIONTOOLBAR
            MENUITEM SEPARATOR
            MENUITEM "E&szköztárak rögzítése",      IDM_TOOLBARS_LOCKTOOLBARS
            MENUITEM "&Testreszabás...",            IDM_TOOLBARS_CUSTOMIZE
        END
        MENUITEM SEPARATOR
        MENUITEM "Placeholder",                 IDM_VIEW_PLACEHOLDER
        MENUITEM SEPARATOR
        MENUITEM "&Automatikus elrendezés",     IDM_ARRANGEICONSBY_AUTOARRANGE
        MENUITEM SEPARATOR
        MENUITEM "Ren&dezés",                   IDM_VIEW_SORTBY
        MENUITEM "Cso&portosítás",              IDM_VIEW_GROUPBY
        MENUITEM "Re&jtett fájlok megjelenítése\tCtrl+H", IDM_VIEW_SHOWHIDDENFILES
        MENUITEM "Fr&issítés\tF5",              IDM_VIEW_REFRESH
        MENUITEM "Megjelenítendő &oszlopok...", IDM_VIEW_SELECTCOLUMNS
        MENUITEM "Oszlopok automatik&us méretezése", IDM_VIEW_AUTOSIZECOLUMNS
        MENUITEM "Oszlopok &beállításainak alapértelmezetté tétele", IDM_VIEW_SAVECOLUMNLAYOUTASDEFAULT
        MENUITEM "R&észletek ablak színeinek megváltoztatása...", IDM_VIEW_CHANGEDISPLAYCOLOURS
        MENUITEM SEPARATOR
        POPUP "S&zűrő"
        BEGIN
            MENUITEM "Szűrő &beállítása...\tCtrl+Shift+F", IDM_FILTER_FILTERRESULTS
            MENUITEM "Szűrő &alkalmazása\tCtrl+G",  IDM_FILTER_APPLYFILTER
        END
    END
    POPUP "&Akciók"
    BEGIN
        MENUITEM "Új &mappa\tCtrl+N",           IDM_ACTIONS_NEWFOLDER
        MENUITEM SEPARATOR
        MENUITEM "Fájl &szétdarabolása...",     IDM_ACTIONS_SPLITFILE
        MENUITEM "Fájlok &összefűzése...",      IDM_ACTIONS_MERGEFILES
        MENUITEM "Fájl(ok)...",                 IDM_ACTIONS_DESTROYFILES
    END
    POPUP "&Ugrás"
    BEGIN
        MENUITEM "&Vissza\tAlt+Left",           IDM_GO_BACK
        MENUITEM "&Előre\tAlt+Right",           IDM_GO_FORWARD
        MENUITEM "E&gy szinttel feljebb\tBackspace", IDM_GO_UPONELEVEL
        MENUITEM SEPARATOR
        MENUITEM "Placeholder",                 IDM_GO_MYCOMPUTER
        MENUITEM "Placeholder",                 IDM_GO_MYDOCUMENTS
        MENUITEM "Placeholder",                 IDM_GO_MYMUSIC
        MENUITEM "Placeholder",                 IDM_GO_MYPICTURES
        MENUITEM "Placeholder",                 IDM_GO_DESKTOP
        MENUITEM SEPARATOR
        MENUITEM "Placeholder",                 IDM_GO_RECYCLEBIN
        MENUITEM "Placeholder",                 IDM_GO_CONTROLPANEL
        MENUITEM "Placeholder",                 IDM_GO_PRINTERS
        MENUITEM "Placeholder",                 IDM_GO_CDBURNING
        MENUITEM "Placeholder",                 IDM_GO_MYNETWORKPLACES
        MENUITEM "Placeholder",                 IDM_GO_NETWORKCONNECTIONS
    END
    POPUP "Kö&nyvjelzők"
    BEGIN
        MENUITEM "&Lap megjelölése...\tCtrl+D", IDM_BOOKMARKS_BOOKMARKTHISTAB
        MENUITEM "Könyvjelzők &szervezése...\tCtrl+B", IDM_BOOKMARKS_ORGANIZEBOOKMARKS
        MENUITEM SEPARATOR
    END
    POPUP "&Eszközök"
    BEGIN
        MENUITEM "&Keresés...\tCtrl+F",         IDM_TOOLS_SEARCH
        MENUITEM "&Színek megváltoztatása...",  IDM_TOOLS_CUSTOMIZECOLORS
        MENUITEM SEPARATOR
        MENUITEM "&Beállítások...",             IDM_TOOLS_OPTIONS
    END
    POPUP "&Súgó"
    BEGIN
        MENUITEM "&Súgó\tF1",                   IDM_HELP_HELP
        MENUITEM SEPARATOR
        MENUITEM "Win32Explorer névjegye...",      IDM_HELP_ABOUT
    END
END

