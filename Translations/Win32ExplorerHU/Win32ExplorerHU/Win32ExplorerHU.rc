IDR_MAINMENU MENU
BEGIN
    POPUP "&Fájl"
    BEGIN
        MENUITEM "&Új lap\tCtrl+T",             IDM_FILE_NEWTAB
        MENUITEM "Lap &bezárása\tCtrl+W",       IDM_FILE_CLOSETAB
        MENUITEM "Ablak &klónozása",            IDM_FILE_CLONEWINDOW
        MENUITEM SEPARATOR
        MENUITEM "Mappa&lista mentése...",      IDM_FILE_SAVEDIRECTORYLISTING
        MENUITEM "Parancs&sor megjelenítése",   IDM_FILE_SHOWCOMMANDPROMPT
        MENUITEM "Ma&ppa elérési útvonalának másolása\tCtrl+Shift+P", IDM_FILE_COPYFOLDERPATH
        MENUITEM "F&ájlok elérési útvonalainak másolása", IDM_FILE_COPYITEMPATH
