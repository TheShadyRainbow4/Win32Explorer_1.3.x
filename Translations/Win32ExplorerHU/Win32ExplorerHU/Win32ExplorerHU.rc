        MENUITEM "Át&nevezés\tF2",              IDM_FILE_RENAME
        MENUITEM "P&roperties\tAlt+Enter",      IDM_FILE_PROPERTIES
        MENUITEM SEPARATOR
        MENUITEM "Be&zárás",                    IDM_FILE_EXIT
    END
    POPUP "Sze&rkesztés"
    BEGIN
        MENUITEM "&Visszavonás\tCtrl+Z",        IDM_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "&Kivágás\tCtrl+X",            IDM_EDIT_CUT
        MENUITEM "&Másolás\tCtrl+C",            IDM_EDIT_COPY
        MENUITEM "&Beillezstés\tCtrl+V",        IDM_EDIT_PASTE
        MENUITEM "&Parancssor beillesztése\tCtrl+Shift+V", IDM_EDIT_PASTESHORTCUT
        MENUITEM "Kemény &link beillesztése",   IDM_EDIT_PASTEHARDLINK
        MENUITEM SEPARATOR
        MENUITEM "M&ásolás mappába\tCtrl+Shift+C", IDM_EDIT_COPYTOFOLDER
        MENUITEM "&Áthelyezés mappába\tCtrl+Shift+M", IDM_EDIT_MOVETOFOLDER
        MENUITEM SEPARATOR
        MENUITEM "&Slack terület mentése...",   IDM_EDIT_SHOWFILESLACK
        MENUITEM "&Hivatkozás megoldása",       IDM_EDIT_RESOLVELINK
    END
    POPUP "&Kijelölés"
    BEGIN
        MENUITEM "&Összes kijelölése\tCtrl+A",  IDM_EDIT_SELECTALL
        MENUITEM "Kijelölés &megfordítása\tCtrl+I", IDM_EDIT_INVERTSELECTION
        MENUITEM "&Azonos típusúak kijelölése", IDM_EDIT_SELECTALLFOLDERS
        MENUITEM "Kijelölés &visszavonása\tCtrl+Shift+N", IDM_EDIT_SELECTNONE
