IDR_MAINMENU MENU
BEGIN
    POPUP "&Arkiv"
    BEGIN
        MENUITEM "&Ny flik\tCtrl+T",            IDM_FILE_NEWTAB
        MENUITEM "&Stäng flik\tCtrl+W",         IDM_FILE_CLOSETAB
        MENUITEM "&Klona fönster",              IDM_FILE_CLONEWINDOW
        MENUITEM SEPARATOR
        MENUITEM "Spara mapp-/&fillista...",    IDM_FILE_SAVEDIRECTORYLISTING
        MENUITEM "Öppna kommando&tolken här",   IDM_FILE_SHOWCOMMANDPROMPT
