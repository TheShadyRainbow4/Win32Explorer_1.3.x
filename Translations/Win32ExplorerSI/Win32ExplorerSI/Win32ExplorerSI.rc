        BEGIN
            MENUITEM "ලිපින තීරුව",                IDM_TOOLBARS_ADDRESSBAR
            MENUITEM "මෙවලම් තීරුව",               IDM_TOOLBARS_MAINTOOLBAR
            MENUITEM "&Bookmarks",                  IDM_TOOLBARS_BOOKMARKSTOOLBAR
            MENUITEM "&Drives",                     IDM_TOOLBARS_DRIVES
            MENUITEM "Application &Toolbar",        IDM_TOOLBARS_APPLICATIONTOOLBAR
            MENUITEM SEPARATOR
            MENUITEM "&Lock Toolbars",              IDM_TOOLBARS_LOCKTOOLBARS
            MENUITEM "රිසිකරණ...",               IDM_TOOLBARS_CUSTOMIZE
        END
        MENUITEM SEPARATOR
