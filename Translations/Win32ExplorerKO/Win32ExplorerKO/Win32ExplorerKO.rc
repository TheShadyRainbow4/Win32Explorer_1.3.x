        MENUITEM "삭제(&D)\tDelete",             IDM_FILE_DELETE
        MENUITEM "영구 삭제(&P)\tShift+Delete", IDM_FILE_DELETEPERMANENTLY
        MENUITEM "다른 이름으로(&M)\tF2",                 IDM_FILE_RENAME
        MENUITEM "속성(&R)\tAlt+Enter",      IDM_FILE_PROPERTIES
        MENUITEM SEPARATOR
        MENUITEM "종료(&E)",                       IDM_FILE_EXIT
    END
    POPUP "편집(&E)"
    BEGIN
        MENUITEM "이전으로(&U)\tCtrl+Z",               IDM_EDIT_UNDO
