        MENUITEM "보이는 작업창 색상 변경(&P)...", IDM_VIEW_CHANGEDISPLAYCOLOURS
        MENUITEM SEPARATOR
        POPUP "필터(&F)"
        BEGIN
            MENUITEM "필터 설정(&S)...\tCtrl+Shift+F", IDM_FILTER_FILTERRESULTS
            MENUITEM "필터 적용(&A)\tCtrl+G",       IDM_FILTER_APPLYFILTER
        END
    END
    POPUP "작업(&A)"
    BEGIN
