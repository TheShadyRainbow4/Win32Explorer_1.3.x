IDR_MAINMENU MENU
BEGIN
    POPUP "파일(&F)"
    BEGIN
        MENUITEM "새 탭(&N)\tCtrl+T",            IDM_FILE_NEWTAB
        MENUITEM "탭 닫기(&C)\tCtrl+W",          IDM_FILE_CLOSETAB
        MENUITEM "작업창 복제(&W)",               IDM_FILE_CLONEWINDOW
        MENUITEM SEPARATOR
        MENUITEM "폴더 목록 저장(&L)...",  IDM_FILE_SAVEDIRECTORYLISTING
        MENUITEM "명령어 라인 보이기(&S)",        IDM_FILE_SHOWCOMMANDPROMPT
        MENUITEM "폴더 경로 복사(&F)\tCtrl+Shift+P", IDM_FILE_COPYFOLDERPATH
