        MENUITEM "하드 링크 붙여넣기(&H)",            IDM_EDIT_PASTEHARDLINK
        MENUITEM SEPARATOR
        MENUITEM "폴더 복사(&F)\tCtrl+Shift+C", IDM_EDIT_COPYTOFOLDER
