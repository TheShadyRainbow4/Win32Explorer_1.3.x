        END
        MENUITEM SEPARATOR
        MENUITEM "Placeholder",                 IDM_VIEW_PLACEHOLDER
        MENUITEM SEPARATOR
        MENUITEM "자동 배열(&A)",               IDM_ARRANGEICONSBY_AUTOARRANGE
        MENUITEM SEPARATOR
        MENUITEM "정렬(&O)",                    IDM_VIEW_SORTBY
        MENUITEM "그룹(&G)",                   IDM_VIEW_GROUPBY
