        MENUITEM "새로이(&R)\tF5",                IDM_VIEW_REFRESH
        MENUITEM "열 선택(&C)...",          IDM_VIEW_SELECTCOLUMNS
        MENUITEM "열 자동크기(&U)",           IDM_VIEW_AUTOSIZECOLUMNS
