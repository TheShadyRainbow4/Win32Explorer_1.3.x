// Menu
//

IDR_MAINMENU MENU
BEGIN
    POPUP "&Archivo"
    BEGIN
        MENUITEM "&Nueva pestaña\tCtrl+T",      IDM_FILE_NEWTAB
        MENUITEM "&Cerrar pestaña\tCtrl+W",     IDM_FILE_CLOSETAB
