        MENUITEM SEPARATOR
        MENUITEM "Копіювати в &Теку\tCtrl+Shift+C", IDM_EDIT_COPYTOFOLDER
        MENUITEM "Пере&містити в Теку\tCtrl+Shift+M", IDM_EDIT_MOVETOFOLDER
        MENUITEM SEPARATOR
        MENUITEM "Зберегти Файлову Поро&жнину...",         IDM_EDIT_SHOWFILESLACK
