        MENUITEM "Виділити Всі Цього ж &Типу",    IDM_EDIT_SELECTALLFOLDERS
        MENUITEM "&Скасувати Виділення\tCtrl+Shift+N",  IDM_EDIT_SELECTNONE
        MENUITEM "Виділити за &Шаблоном...\tCtrl+Shift+S", IDM_EDIT_WILDCARDSELECTION
        MENUITEM "&Зняти Виділення за Шаблоном...\tCtrl+Shift+D", IDM_EDIT_WILDCARDDESELECT
    END
    POPUP "&Вигляд"
    BEGIN
        MENUITEM "&Рядок Стану",                 IDM_VIEW_STATUSBAR
        MENUITEM "&Теки",                    IDM_VIEW_FOLDERS
        MENUITEM "&Вікно Попереднього Перегляду",             IDM_VIEW_DISPLAYWINDOW
        POPUP "Панелі &Інструментів"
        BEGIN
            MENUITEM "Рядок &Адреси",                IDM_TOOLBARS_ADDRESSBAR
            MENUITEM "О&сновна Панель",               IDM_TOOLBARS_MAINTOOLBAR
            MENUITEM "&Закладки",                  IDM_TOOLBARS_BOOKMARKSTOOLBAR
            MENUITEM "&Диски",                     IDM_TOOLBARS_DRIVES
