            MENUITEM SEPARATOR
            MENUITEM "За&кріпити Панелі",              IDM_TOOLBARS_LOCKTOOLBARS
            MENUITEM "&Налаштувати...",               IDM_TOOLBARS_CUSTOMIZE
        END
        MENUITEM SEPARATOR
        MENUITEM "Placeholder",                 IDM_VIEW_PLACEHOLDER
        MENUITEM SEPARATOR
        MENUITEM "&Автоматичне Впорядкування",               IDM_ARRANGEICONSBY_AUTOARRANGE
        MENUITEM SEPARATOR
        MENUITEM "Со&ртувати за",                    IDM_VIEW_SORTBY
        MENUITEM "Гр&упувати за",                   IDM_VIEW_GROUPBY
        MENUITEM "Показувати Пр&иховані Файли\tCtrl+H",  IDM_VIEW_SHOWHIDDENFILES
        MENUITEM "&Оновити\tF5",                IDM_VIEW_REFRESH
        MENUITEM "Вибрати &Колонки...",          IDM_VIEW_SELECTCOLUMNS
        MENUITEM "Ав&торозмір Колонок",           IDM_VIEW_AUTOSIZECOLUMNS
        MENUITEM "Зберегти набір Колонок як Стандартний", IDM_VIEW_SAVECOLUMNLAYOUTASDEFAULT
        MENUITEM "Змінити Ко&льори Вікна Попереднього Перегляду...", IDM_VIEW_CHANGEDISPLAYCOLOURS
        MENUITEM SEPARATOR
        POPUP "&Фільтр"
        BEGIN
            MENUITEM "&Задати Фільтр...\tCtrl+Shift+F", IDM_FILTER_FILTERRESULTS
            MENUITEM "За&стосувати Фільтр\tCtrl+G",       IDM_FILTER_APPLYFILTER
        END
    END
    POPUP "Д&ії"
    BEGIN
