IDR_MAINMENU MENU
BEGIN
    POPUP "??(&F)"
    BEGIN
        MENUITEM "? ?(&N)\tCtrl+T",            IDM_FILE_NEWTAB
        MENUITEM "? ??(&C)\tCtrl+W",          IDM_FILE_CLOSETAB
        MENUITEM "??? ??(&W)",               IDM_FILE_CLONEWINDOW
        MENUITEM SEPARATOR
        MENUITEM "?? ?? ??(&L)...",  IDM_FILE_SAVEDIRECTORYLISTING
        MENUITEM "??? ?? ???(&S)",        IDM_FILE_SHOWCOMMANDPROMPT
        MENUITEM "?? ?? ??(&F)\tCtrl+Shift+P", IDM_FILE_COPYFOLDERPATH
        MENUITEM "?? ?? ??(&O)",            IDM_FILE_COPYITEMPATH
        MENUITEM "?? ?? ?? ??(&U)",  IDM_FILE_COPYUNIVERSALFILEPATHS
        MENUITEM "? ??? ??(&T)",           IDM_FILE_COPYCOLUMNTEXT
        MENUITEM SEPARATOR
        MENUITEM "?? ??(&A)...",     IDM_FILE_SETFILEATTRIBUTES
        MENUITEM "??(&D)\tDelete",             IDM_FILE_DELETE
        MENUITEM "?? ??(&P)\tShift+Delete", IDM_FILE_DELETEPERMANENTLY
        MENUITEM "?? ????(&M)\tF2",                 IDM_FILE_RENAME
        MENUITEM "??(&R)\tAlt+Enter",      IDM_FILE_PROPERTIES
        MENUITEM SEPARATOR
        MENUITEM "??(&E)",                       IDM_FILE_EXIT
    END
    POPUP "??(&E)"
    BEGIN
        MENUITEM "????(&U)\tCtrl+Z",               IDM_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "????(&T)\tCtrl+X",                IDM_EDIT_CUT
        MENUITEM "??(&C)\tCtrl+C",               IDM_EDIT_COPY
        MENUITEM "????(&P)\tCtrl+V",              IDM_EDIT_PASTE
        MENUITEM "???? ????(&S)\tCtrl+Shift+V", IDM_EDIT_PASTESHORTCUT
        MENUITEM "?? ?? ????(&H)",            IDM_EDIT_PASTEHARDLINK
        MENUITEM SEPARATOR
        MENUITEM "?? ??(&F)\tCtrl+Shift+C", IDM_EDIT_COPYTOFOLDER
        MENUITEM "?? ??(&V)\tCtrl+Shift+M", IDM_EDIT_MOVETOFOLDER
        MENUITEM SEPARATOR
        MENUITEM "?? ?? ?? ??(&L)...",         IDM_EDIT_SHOWFILESLACK
        MENUITEM "?? ??(&R)",               IDM_EDIT_RESOLVELINK
    END
    POPUP "??(&S)"
    BEGIN
        MENUITEM "?? ??(&A)\tCtrl+A",         IDM_EDIT_SELECTALL
        MENUITEM "?? ??(&I)\tCtrl+I",   IDM_EDIT_INVERTSELECTION
        MENUITEM "??? ?? ?? ??(&T)",    IDM_EDIT_SELECTALLFOLDERS
        MENUITEM "?? ??(&N)\tCtrl+Shift+N",  IDM_EDIT_SELECTNONE
        MENUITEM "?? ???? ??(&S)...\tCtrl+Shift+S", IDM_EDIT_WILDCARDSELECTION
        MENUITEM "?? ???? ????(&D)...\tCtrl+Shift+D", IDM_EDIT_WILDCARDDESELECT
    END
    POPUP "??(&V)"
