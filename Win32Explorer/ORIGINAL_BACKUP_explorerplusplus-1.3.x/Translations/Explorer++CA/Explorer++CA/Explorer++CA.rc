IDR_MAINMENU MENU
BEGIN
    POPUP "&Fitxer"
    BEGIN
        MENUITEM "&Nou\tTabCtrl+T",            IDM_FILE_NEWTAB
        MENUITEM "&Tanca\tTabCtrl+W",          IDM_FILE_CLOSETAB
