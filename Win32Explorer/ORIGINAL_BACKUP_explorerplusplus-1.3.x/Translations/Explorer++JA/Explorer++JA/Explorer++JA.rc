        BEGIN
            MENUITEM "??????(&S)...\tCtrl+Shift+F", IDM_FILTER_FILTERRESULTS
            MENUITEM "???????(&A)\tCtrl+G",       IDM_FILTER_APPLYFILTER
        END
    END
    POPUP "??(&A)"
    BEGIN
        MENUITEM "???????(&F)\tCtrl+N",         IDM_ACTIONS_NEWFOLDER
        MENUITEM SEPARATOR
        MENUITEM "???????(&S)...",              IDM_ACTIONS_SPLITFILE
        MENUITEM "???????(&M)...",             IDM_ACTIONS_MERGEFILES
        MENUITEM "???????(&D)...",         IDM_ACTIONS_DESTROYFILES
    END
    POPUP "???(&G)"
    BEGIN
        MENUITEM "??(&B)\tAlt+Left",             IDM_GO_BACK
        MENUITEM "??(&F)\tAlt+Right",         IDM_GO_FORWARD
        MENUITEM "?????(&U)\tBackspace",    IDM_GO_UPONELEVEL
        MENUITEM SEPARATOR
        MENUITEM "Placeholder",                 IDM_GO_MYCOMPUTER
        MENUITEM "Placeholder",                 IDM_GO_MYDOCUMENTS
        MENUITEM "Placeholder",                 IDM_GO_MYMUSIC
        MENUITEM "Placeholder",                 IDM_GO_MYPICTURES
        MENUITEM "Placeholder",                 IDM_GO_DESKTOP
        MENUITEM SEPARATOR
        MENUITEM "Placeholder",                 IDM_GO_RECYCLEBIN
        MENUITEM "Placeholder",                 IDM_GO_CONTROLPANEL
        MENUITEM "Placeholder",                 IDM_GO_PRINTERS
        MENUITEM "Placeholder",                 IDM_GO_CDBURNING
        MENUITEM "Placeholder",                 IDM_GO_MYNETWORKPLACES
        MENUITEM "Placeholder",                 IDM_GO_NETWORKCONNECTIONS
    END
    POPUP "??????(&B)"
    BEGIN
        MENUITEM "??Tab??????????(&B)...\tCtrl+D", IDM_BOOKMARKS_BOOKMARKTHISTAB
        MENUITEM "?????????(&O)...\tCtrl+B", IDM_BOOKMARKS_ORGANIZEBOOKMARKS
        MENUITEM SEPARATOR
