        MENUITEM SEPARATOR
        MENUITEM "????(&A)",               IDM_ARRANGEICONSBY_AUTOARRANGE
        MENUITEM SEPARATOR
        MENUITEM "????(&O)",                    IDM_VIEW_SORTBY
        MENUITEM "????(&G)",                   IDM_VIEW_GROUPBY
